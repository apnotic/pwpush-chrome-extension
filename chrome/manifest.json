{
  "manifest_version": 3,
  "name": "Password Pusher Connector",
  "description": "Connect Chrome to OSS, Pro, or self-hosted Password Pusher instances via APIv2.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://oss.pwpush.com/*",
    "https://eu.pwpush.com/*",
    "https://us.pwpush.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Password Pusher",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content/selection.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
